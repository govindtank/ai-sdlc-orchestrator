# Environment variables for AI SDLC Orchestrator
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_sdlc
DATABASE_URL=postgresql://postgres:postgres@db/ai_sdlc

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Configuration
# Set LLM_PROVIDER to one of: mock, openai, huggingface
LLM_PROVIDER=mock

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# HuggingFace Configuration (if using huggingface provider)
HF_ENDPOINT_URL=https://api-inference.huggingface.co/models/
HF_API_KEY=your-huggingface-api-key-here

# Application
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]